{
  "name": "kodify-system",
  "version": "1.0.0",
  "description": "Premium Bilingual POS & Retail Management Desktop Application",
  "main": "dist-electron/main.js",
  "author": "Yaqoot Team",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "dist": "npm run build && electron-builder -p always"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "chart.js": "^4.4.3",
    "drizzle-orm": "^0.30.10",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.40.0",
    "jspdf": "^2.5.1",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "drizzle-kit": "^0.21.4",
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.kodify.system",
    "productName": "KODIFY System",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "extraResources": [
      "drizzle"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "icon": "public/5.png",
    "win": {
      "target": "nsis",
      "icon": "public/5.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "Hamodey67",
      "repo": "kodify-system"
    }
  }
}
